# Copy this file to .streamlit/secrets.toml and fill in your values
# This file should NOT be committed to git (add to .gitignore)

# Supabase (free tier: https://supabase.com)
SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_ANON_KEY = "your-anon-key-here"

# OpenRouter (reads from ~/.claude/settings.json)
# These match the parent settings: ANTHROPIC_AUTH_TOKEN, ANTHROPIC_BASE_URL, ANTHROPIC_MODEL
ANTHROPIC_AUTH_TOKEN = "sk-or-v1-..."
ANTHROPIC_BASE_URL = "https://openrouter.ai/api"
ANTHROPIC_MODEL = "tencent/hy3-preview:free"

# Keep ANTHROPIC_API_KEY as fallback (same token)
ANTHROPIC_API_KEY = "sk-or-v1-..."

# Backend API (if using separate backend)
# BACKEND_URL = "https://your-backend.onrender.com"

# Streamlit Cloud uses secrets.toml automatically
# For local development, this file is read by streamlit
